# Firewalla Feed Automator — Environment Configuration
# Copy this file to .env and adjust values as needed.
# The install.sh script generates .env automatically.
#
# Firewalla API key and MSP domain are configured on first visit
# to the web UI (Setup page) — you do NOT need to set them here.

# ── App Settings ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
MAX_ENTRIES_PER_LIST=2000

# ── Security ──────────────────────────────────────────────────────────────────
# Used to sign the session cookie. Generated automatically by install.sh.
# Change this to invalidate all existing sessions.
SECRET_KEY=change-me-to-a-random-secret-key
