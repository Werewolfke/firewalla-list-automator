# Firewalla Feed Automator - Environment Configuration
# Copy this file to .env and fill in your values

# ── Firewalla MSP API ─────────────────────────────────────────────────────────
# Your MSP domain: the {id} part of {id}.firewalla.net
FIREWALLA_MSP_DOMAIN=mydomain.firewalla.net
FIREWALLA_API_KEY=your_personal_access_token

# ── App Settings ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
MAX_ENTRIES_PER_LIST=2000

# ── Security (change this in production!) ────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
